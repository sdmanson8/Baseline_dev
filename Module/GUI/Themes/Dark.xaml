<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Color x:Key="Color.WindowBg">#0E111A</Color>
	<Color x:Key="Color.HeaderBg">#121624</Color>
	<Color x:Key="Color.Surface">#161A26</Color>
	<Color x:Key="Color.SurfaceElevated">#1E2433</Color>
	<Color x:Key="Color.SurfaceControl">#262D40</Color>
	<Color x:Key="Color.SurfaceHover">#30384E</Color>
	<Color x:Key="Color.TextPrimary">#F4F7FF</Color>
	<Color x:Key="Color.TextSecondary">#CDD6EA</Color>
	<Color x:Key="Color.TextMuted">#A3ADC6</Color>
	<Color x:Key="Color.TextDisabled">#7E89A8</Color>
	<Color x:Key="Color.Border">#2430445A</Color>
	<Color x:Key="Color.BorderStrong">#3C4A66</Color>
	<Color x:Key="Color.Accent">#7CB7FF</Color>
	<Color x:Key="Color.AccentHover">#9ACAFF</Color>
	<Color x:Key="Color.AccentPress">#4D9CFF</Color>
	<Color x:Key="Color.Success">#35D07F</Color>
	<Color x:Key="Color.Warning">#D6A84A</Color>
	<Color x:Key="Color.Danger">#FF6B8A</Color>
	<Color x:Key="Color.LogBg">#1E2433</Color>
	<Color x:Key="Color.LogDefault">#F4F7FF</Color>
	<Color x:Key="Color.LogInfo">#7CB7FF</Color>
	<Color x:Key="Color.LogSuccess">#35D07F</Color>
	<Color x:Key="Color.LogWarning">#D6A84A</Color>
	<Color x:Key="Color.LogError">#FF6B8A</Color>
	<Color x:Key="Color.InputBg">#262D40</Color>
	<Color x:Key="Color.InputHoverBg">#30384E</Color>
	<Color x:Key="Color.ButtonBg">#00FFFFFF</Color>
	<Color x:Key="Color.ButtonHoverBg">#252D40</Color>
	<Color x:Key="Color.ButtonPressBg">#262D40</Color>
	<Color x:Key="Color.ButtonBorder">#1FFFFFFF</Color>
	<Color x:Key="Color.Progress">#35D07F</Color>
	<Color x:Key="Color.ProgressTrack">#262D40</Color>
	<Color x:Key="Color.Overlay">#D8000000</Color>
	<Color x:Key="Color.SplashBackdropStart">#151A2A</Color>
	<Color x:Key="Color.SplashBackdropEnd">#0A0F1A</Color>
	<Color x:Key="Color.SplashCard">#0FFFFFFF</Color>
	<Color x:Key="Color.SplashCardBorder">#00FFFFFF</Color>
	<Color x:Key="Color.SplashSubtitle">#CDD6EA</Color>
	<Color x:Key="Color.SplashStepActive">#E6EBFF</Color>

	<SolidColorBrush x:Key="Brush.WindowBg" Color="{StaticResource Color.WindowBg}"/>
	<SolidColorBrush x:Key="Brush.HeaderBg" Color="{StaticResource Color.HeaderBg}"/>
	<SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
	<SolidColorBrush x:Key="Brush.SurfaceElevated" Color="{StaticResource Color.SurfaceElevated}"/>
	<SolidColorBrush x:Key="Brush.SurfaceControl" Color="{StaticResource Color.SurfaceControl}"/>
	<SolidColorBrush x:Key="Brush.SurfaceHover" Color="{StaticResource Color.SurfaceHover}"/>
	<SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}"/>
	<SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}"/>
	<SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}"/>
	<SolidColorBrush x:Key="Brush.TextDisabled" Color="{StaticResource Color.TextDisabled}"/>
	<SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>
	<SolidColorBrush x:Key="Brush.BorderSubtle" Color="{StaticResource Color.Border}"/>
	<SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}"/>
	<SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
	<SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}"/>
	<SolidColorBrush x:Key="Brush.AccentPress" Color="{StaticResource Color.AccentPress}"/>
	<SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
	<SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
	<SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
	<SolidColorBrush x:Key="Brush.LogBg" Color="{StaticResource Color.LogBg}"/>
	<SolidColorBrush x:Key="Brush.LogDefault" Color="{StaticResource Color.LogDefault}"/>
	<SolidColorBrush x:Key="Brush.LogInfo" Color="{StaticResource Color.LogInfo}"/>
	<SolidColorBrush x:Key="Brush.LogSuccess" Color="{StaticResource Color.LogSuccess}"/>
	<SolidColorBrush x:Key="Brush.LogWarning" Color="{StaticResource Color.LogWarning}"/>
	<SolidColorBrush x:Key="Brush.LogError" Color="{StaticResource Color.LogError}"/>
	<SolidColorBrush x:Key="Brush.InputBg" Color="{StaticResource Color.InputBg}"/>
	<SolidColorBrush x:Key="Brush.InputHoverBg" Color="{StaticResource Color.InputHoverBg}"/>
	<SolidColorBrush x:Key="Brush.ButtonBg" Color="{StaticResource Color.ButtonBg}"/>
	<SolidColorBrush x:Key="Brush.ButtonHoverBg" Color="{StaticResource Color.ButtonHoverBg}"/>
	<SolidColorBrush x:Key="Brush.ButtonPressBg" Color="{StaticResource Color.ButtonPressBg}"/>
	<SolidColorBrush x:Key="Brush.ButtonBorder" Color="{StaticResource Color.ButtonBorder}"/>
	<SolidColorBrush x:Key="Brush.Progress" Color="{StaticResource Color.Progress}"/>
	<SolidColorBrush x:Key="Brush.ProgressTrack" Color="{StaticResource Color.ProgressTrack}"/>
	<SolidColorBrush x:Key="Brush.Overlay" Color="{StaticResource Color.Overlay}"/>
	<SolidColorBrush x:Key="Brush.SplashCard" Color="{StaticResource Color.SplashCard}"/>
	<SolidColorBrush x:Key="Brush.SplashCardBorder" Color="{StaticResource Color.SplashCardBorder}"/>
	<SolidColorBrush x:Key="Brush.SplashSubtitle" Color="{StaticResource Color.SplashSubtitle}"/>
	<SolidColorBrush x:Key="Brush.SplashStepActive" Color="{StaticResource Color.SplashStepActive}"/>
	<RadialGradientBrush x:Key="Brush.SplashBackdrop" Center="0.5,0.34" GradientOrigin="0.5,0.30" RadiusX="0.85" RadiusY="0.78">
		<GradientStop Color="{StaticResource Color.SplashBackdropStart}" Offset="0"/>
		<GradientStop Color="{StaticResource Color.SplashBackdropEnd}" Offset="1"/>
	</RadialGradientBrush>

	<SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource Color.WindowBg}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource Color.TextPrimary}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource Color.SurfaceElevated}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource Color.TextPrimary}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="{StaticResource Color.SurfaceHover}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="{StaticResource Color.BorderStrong}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="{StaticResource Color.SurfaceElevated}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="{StaticResource Color.TextPrimary}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource Color.Accent}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource Color.WindowBg}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{StaticResource Color.TextDisabled}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.InactiveBorderBrushKey}" Color="{StaticResource Color.Border}"/>
	<SolidColorBrush x:Key="{x:Static SystemColors.ActiveBorderBrushKey}" Color="{StaticResource Color.Accent}"/>

	<Style TargetType="Window">
		<Setter Property="Background" Value="{DynamicResource Brush.WindowBg}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="Label">
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="TextBox">
		<Setter Property="Background" Value="{DynamicResource Brush.InputBg}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
		<Setter Property="CaretBrush" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="SelectionBrush" Value="{DynamicResource Brush.Accent}"/>
	</Style>
	<Style TargetType="PasswordBox">
		<Setter Property="Background" Value="{DynamicResource Brush.InputBg}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
		<Setter Property="CaretBrush" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="SelectionBrush" Value="{DynamicResource Brush.Accent}"/>
	</Style>
	<Style TargetType="ComboBox">
		<Setter Property="Background" Value="{DynamicResource Brush.InputBg}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
	</Style>
	<Style TargetType="ComboBoxItem">
		<Setter Property="Background" Value="{DynamicResource Brush.SurfaceElevated}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="Button">
		<Setter Property="Background" Value="{DynamicResource Brush.ButtonBg}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.ButtonBorder}"/>
	</Style>
	<Style TargetType="CheckBox">
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="RadioButton">
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="ListBox">
		<Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
	</Style>
	<Style TargetType="ListBoxItem">
		<Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="Menu">
		<Setter Property="Background" Value="{DynamicResource Brush.HeaderBg}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="ContextMenu">
		<Setter Property="Background" Value="{DynamicResource Brush.SurfaceElevated}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="MenuItem">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
	<Style TargetType="Separator">
		<Setter Property="Background" Value="{DynamicResource Brush.Border}"/>
	</Style>
	<Style TargetType="ToolTip">
		<Setter Property="Background" Value="{DynamicResource Brush.SurfaceElevated}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
		<Setter Property="Padding" Value="0"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type ToolTip}">
					<Border
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="1"
						CornerRadius="8"
						MaxWidth="420"
						Padding="10,7"
						SnapsToDevicePixels="True">
						<ContentPresenter RecognizesAccessKey="True"/>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style TargetType="FlowDocumentScrollViewer">
		<Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
		<Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
	</Style>
</ResourceDictionary>
